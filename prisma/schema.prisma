generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  password String
  role Role @default(USER)
  no_telp String
  alamat String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("users")
}

model Spesialis {
  id Int @id @default(autoincrement())
  name String
  description String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  dokter Dokter[]

  @@map("spesialis")
}

model Dokter {
  id Int @id @default(autoincrement())
  nama_dokter String
  jenis_kelamin String
  tanggal_lahir DateTime
  id_spesialis Int
  spesialis Spesialis @relation(fields: [id_spesialis], references: [id])
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("dokter")
}